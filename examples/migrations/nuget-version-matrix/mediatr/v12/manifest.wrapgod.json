          ]
        }
      ],
      "notes": "BREAKING: Constraint relaxed from 'where TRequest : IBaseRequest' to 'where TRequest : notnull'."
    },
    {
      "name": "MediatR.IRequestPostProcessor`2",
      "namespace": "MediatR",
      "kind": "Interface",
      "genericParameters": [
