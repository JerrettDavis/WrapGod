          "kind": "Method",
          "returnType": "Task<object?>",
          "parameters": [
            { "name": "request", "type": "object" },
            { "name": "cancellationToken", "type": "CancellationToken" }
          ]
        },
        {
          "name": "CreateStream",
          "kind": "Method",
