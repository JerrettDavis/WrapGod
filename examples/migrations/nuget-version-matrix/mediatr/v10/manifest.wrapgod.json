      ],
      "notes": "NEW in v10. Handler for streaming requests. TRequest constrained to IStreamRequest<TResponse>."
    },
    {
      "name": "MediatR.IStreamPipelineBehavior`2",
      "namespace": "MediatR",
      "kind": "Interface",
      "genericParameters": [
        { "name": "TRequest", "variance": "in", "constraints": ["IStreamRequest<TResponse>"] },
